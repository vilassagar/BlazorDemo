@namespace MxUI.Core.Components

<div class="@ComputedClasses" role="alert" @attributes="AdditionalAttributes">
    <div class="flex gap-3">
        @* Icon *@
        <div class="flex-shrink-0 mt-0.5">
            @switch (Variant)
            {
                case MxAlertVariant.Success:
                    <svg class="h-5 w-5 text-success-600" fill="currentColor" viewBox="0 0 20 20">
                        <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.857-9.809a.75.75 0 00-1.214-.882l-3.483 4.79-1.88-1.88a.75.75 0 10-1.06 1.061l2.5 2.5a.75.75 0 001.137-.089l4-5.5z" clip-rule="evenodd" />
                    </svg>
                    break;
                case MxAlertVariant.Danger:
                    <svg class="h-5 w-5 text-danger-600" fill="currentColor" viewBox="0 0 20 20">
                        <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.28 7.22a.75.75 0 00-1.06 1.06L8.94 10l-1.72 1.72a.75.75 0 101.06 1.06L10 11.06l1.72 1.72a.75.75 0 101.06-1.06L11.06 10l1.72-1.72a.75.75 0 00-1.06-1.06L10 8.94 8.28 7.22z" clip-rule="evenodd" />
                    </svg>
                    break;
                case MxAlertVariant.Warning:
                    <svg class="h-5 w-5 text-warning-600" fill="currentColor" viewBox="0 0 20 20">
                        <path fill-rule="evenodd" d="M8.485 2.495c.673-1.167 2.357-1.167 3.03 0l6.28 10.875c.673 1.167-.17 2.625-1.516 2.625H3.72c-1.347 0-2.189-1.458-1.515-2.625L8.485 2.495zM10 5a.75.75 0 01.75.75v3.5a.75.75 0 01-1.5 0v-3.5A.75.75 0 0110 5zm0 9a1 1 0 100-2 1 1 0 000 2z" clip-rule="evenodd" />
                    </svg>
                    break;
                default:
                    <svg class="h-5 w-5 text-primary-600" fill="currentColor" viewBox="0 0 20 20">
                        <path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7-4a1 1 0 11-2 0 1 1 0 012 0zM9 9a.75.75 0 000 1.5h.253a.25.25 0 01.244.304l-.459 2.066A1.75 1.75 0 0010.747 15H11a.75.75 0 000-1.5h-.253a.25.25 0 01-.244-.304l.459-2.066A1.75 1.75 0 009.253 9H9z" clip-rule="evenodd" />
                    </svg>
                    break;
            }
        </div>

        @* Content *@
        <div class="flex-1 min-w-0">
            @if (!string.IsNullOrEmpty(Title))
            {
                <h4 class="font-semibold text-sm mb-1">@Title</h4>
            }
            <div class="text-sm">
                @ChildContent
            </div>
            @if (ActionContent != null)
            {
                <div class="mt-3">
                    @ActionContent
                </div>
            }
        </div>

        @* Dismiss *@
        @if (Dismissible)
        {
            <button @onclick="HandleDismiss"
                    class="flex-shrink-0 p-1 rounded-md hover:bg-black/5 transition-colors">
                <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
                </svg>
            </button>
        }
    </div>
</div>

@code {
    [Parameter] public RenderFragment? ChildContent { get; set; }
    [Parameter] public RenderFragment? ActionContent { get; set; }
    [Parameter] public string? Title { get; set; }
    [Parameter] public MxAlertVariant Variant { get; set; } = MxAlertVariant.Info;
    [Parameter] public bool Dismissible { get; set; }
    [Parameter] public EventCallback OnDismiss { get; set; }
    [Parameter] public string? Class { get; set; }
    [Parameter(CaptureUnmatchedValues = true)]
    public Dictionary<string, object>? AdditionalAttributes { get; set; }

    private string ComputedClasses
    {
        get
        {
            var classes = new List<string> { "rounded-lg border p-4 animate-fade-in" };

            classes.Add(Variant switch
            {
                MxAlertVariant.Info    => "bg-primary-50 border-primary-200 text-primary-800",
                MxAlertVariant.Success => "bg-success-50 border-success-600/20 text-success-700",
                MxAlertVariant.Warning => "bg-warning-50 border-warning-500/20 text-warning-700",
                MxAlertVariant.Danger  => "bg-danger-50 border-danger-500/20 text-danger-700",
                _ => ""
            });

            if (!string.IsNullOrEmpty(Class)) classes.Add(Class);
            return string.Join(" ", classes);
        }
    }

    private async Task HandleDismiss()
    {
        if (OnDismiss.HasDelegate) await OnDismiss.InvokeAsync();
    }
}

public enum MxAlertVariant { Info, Success, Warning, Danger }
