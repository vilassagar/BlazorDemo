@namespace MxUI.Core.Components
@inject IJSRuntime JS

@if (IsOpen)
{
    <div class="fixed inset-0 z-50 overflow-y-auto" id="@_modalId">
        @* Backdrop *@
        <div class="fixed inset-0 bg-neutral-900/60 backdrop-blur-sm animate-fade-in"
             @onclick="HandleBackdropClick"></div>

        @* Modal Container *@
        <div class="flex min-h-full items-center justify-center p-4">
            <div class="relative w-full @SizeClass bg-surface-base rounded-xl shadow-lg 
                        animate-scale-in z-10 @Class"
                 role="dialog"
                 aria-modal="true"
                 aria-labelledby="@(_modalId + "-title")">
                
                @* Header *@
                @if (HeaderContent != null || !string.IsNullOrEmpty(Title))
                {
                    <div class="flex items-center justify-between px-6 py-4 border-b border-neutral-200">
                        @if (HeaderContent != null)
                        {
                            @HeaderContent
                        }
                        else
                        {
                            <h3 id="@(_modalId + "-title")" 
                                class="text-lg font-semibold text-content-primary">
                                @Title
                            </h3>
                        }
                        @if (ShowCloseButton)
                        {
                            <button @onclick="Close"
                                    class="p-1.5 rounded-lg text-content-muted hover:text-content-primary 
                                           hover:bg-surface-muted transition-colors">
                                <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
                                </svg>
                            </button>
                        }
                    </div>
                }

                @* Body *@
                <div class="px-6 py-4 max-h-[70vh] overflow-y-auto mx-scrollbar">
                    @ChildContent
                </div>

                @* Footer *@
                @if (FooterContent != null)
                {
                    <div class="flex items-center justify-end gap-3 px-6 py-4 border-t border-neutral-100 bg-surface-muted rounded-b-xl">
                        @FooterContent
                    </div>
                }
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public bool IsOpen { get; set; }
    [Parameter] public EventCallback<bool> IsOpenChanged { get; set; }
    [Parameter] public EventCallback OnClose { get; set; }
    [Parameter] public string? Title { get; set; }
    [Parameter] public RenderFragment? ChildContent { get; set; }
    [Parameter] public RenderFragment? HeaderContent { get; set; }
    [Parameter] public RenderFragment? FooterContent { get; set; }
    [Parameter] public MxModalSize Size { get; set; } = MxModalSize.Medium;
    [Parameter] public bool ShowCloseButton { get; set; } = true;
    [Parameter] public bool CloseOnBackdrop { get; set; } = true;
    [Parameter] public bool CloseOnEscape { get; set; } = true;
    [Parameter] public string? Class { get; set; }

    private string _modalId = $"mx-modal-{Guid.NewGuid():N}"[..20];

    private string SizeClass => Size switch
    {
        MxModalSize.Small      => "max-w-sm",
        MxModalSize.Medium     => "max-w-lg",
        MxModalSize.Large      => "max-w-2xl",
        MxModalSize.ExtraLarge => "max-w-4xl",
        MxModalSize.Full       => "max-w-[90vw]",
        _ => "max-w-lg"
    };

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (IsOpen)
        {
            try
            {
                var module = await JS.InvokeAsync<IJSObjectReference>(
                    "import", "./_content/MxUI.Core/js/mxui.js");
                await module.InvokeVoidAsync("MxUI.modalOpen", _modalId);
            }
            catch { /* SSR fallback */ }
        }
    }

    private async Task HandleBackdropClick()
    {
        if (CloseOnBackdrop) await Close();
    }

    private async Task Close()
    {
        try
        {
            var module = await JS.InvokeAsync<IJSObjectReference>(
                "import", "./_content/MxUI.Core/js/mxui.js");
            await module.InvokeVoidAsync("MxUI.modalClose");
        }
        catch { }

        await IsOpenChanged.InvokeAsync(false);
        await OnClose.InvokeAsync();
    }
}

public enum MxModalSize { Small, Medium, Large, ExtraLarge, Full }
