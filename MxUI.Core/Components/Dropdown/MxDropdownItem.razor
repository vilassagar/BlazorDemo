@namespace MxUI.Core.Components

@if (IsDivider)
{
    <div class="my-1 border-t border-neutral-100"></div>
}
else
{
    <button class="@ComputedClasses"
            role="menuitem"
            disabled="@Disabled"
            @onclick="HandleClick">
        @if (IconContent != null)
        {
            <span class="flex-shrink-0 w-5 h-5">@IconContent</span>
        }
        <span class="flex-1 text-left">@ChildContent</span>
        @if (TrailingContent != null)
        {
            <span class="flex-shrink-0 text-content-muted">@TrailingContent</span>
        }
    </button>
}

@code {
    [Parameter] public RenderFragment? ChildContent { get; set; }
    [Parameter] public RenderFragment? IconContent { get; set; }
    [Parameter] public RenderFragment? TrailingContent { get; set; }
    [Parameter] public EventCallback OnClick { get; set; }
    [Parameter] public bool Disabled { get; set; }
    [Parameter] public bool IsDivider { get; set; }
    [Parameter] public bool Danger { get; set; }

    private string ComputedClasses
    {
        get
        {
            var baseClasses = "w-full flex items-center gap-2 px-3 py-2 text-sm transition-colors duration-fast";
            var colorClasses = Danger
                ? "text-danger-600 hover:bg-danger-50"
                : "text-content-primary hover:bg-surface-muted";
            var disabledClasses = Disabled ? "opacity-50 cursor-not-allowed" : "cursor-pointer";
            return $"{baseClasses} {colorClasses} {disabledClasses}";
        }
    }

    private async Task HandleClick()
    {
        if (!Disabled && OnClick.HasDelegate)
            await OnClick.InvokeAsync();
    }
}
