@namespace MxUI.Core.Components
@typeparam TValue

<div class="@WrapperClasses">
    @if (!string.IsNullOrEmpty(Label))
    {
        <label class="block text-sm font-medium text-content-secondary mb-1.5" for="@InputId">
            @Label
            @if (Required)
            {
                <span class="text-danger-500 ml-0.5">*</span>
            }
        </label>
    }

    <div class="relative">
        @if (PrefixContent != null)
        {
            <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none text-content-muted">
                @PrefixContent
            </div>
        }

        <input id="@InputId"
               type="@Type"
               class="@ComputedClasses"
               value="@CurrentValueAsString"
               placeholder="@Placeholder"
               disabled="@Disabled"
               readonly="@ReadOnly"
               required="@Required"
               @oninput="HandleInput"
               @onblur="HandleBlur"
               @onfocus="HandleFocus"
               @attributes="AdditionalAttributes" />

        @if (SuffixContent != null)
        {
            <div class="absolute inset-y-0 right-0 pr-3 flex items-center text-content-muted">
                @SuffixContent
            </div>
        }

        @if (HasError && !string.IsNullOrEmpty(ErrorIcon))
        {
            <div class="absolute inset-y-0 right-0 pr-3 flex items-center pointer-events-none text-danger-500">
                <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7 4a1 1 0 11-2 0 1 1 0 012 0zm-1-9a1 1 0 00-1 1v4a1 1 0 102 0V6a1 1 0 00-1-1z" clip-rule="evenodd" />
                </svg>
            </div>
        }
    </div>

    @if (!string.IsNullOrEmpty(HelperText) && !HasError)
    {
        <p class="mt-1.5 text-xs text-content-muted">@HelperText</p>
    }

    @if (HasError && !string.IsNullOrEmpty(ErrorMessage))
    {
        <p class="mt-1.5 text-xs text-danger-600 flex items-center gap-1">
            @ErrorMessage
        </p>
    }
</div>

@code {
    [Parameter] public string Label { get; set; } = "";
    [Parameter] public string Placeholder { get; set; } = "";
    [Parameter] public string Type { get; set; } = "text";
    [Parameter] public TValue? Value { get; set; }
    [Parameter] public EventCallback<TValue> ValueChanged { get; set; }
    [Parameter] public bool Disabled { get; set; }
    [Parameter] public bool ReadOnly { get; set; }
    [Parameter] public bool Required { get; set; }
    [Parameter] public bool HasError { get; set; }
    [Parameter] public string? ErrorMessage { get; set; }
    [Parameter] public string? HelperText { get; set; }
    [Parameter] public string ErrorIcon { get; set; } = "!";
    [Parameter] public MxInputSize Size { get; set; } = MxInputSize.Medium;
    [Parameter] public RenderFragment? PrefixContent { get; set; }
    [Parameter] public RenderFragment? SuffixContent { get; set; }
    [Parameter] public EventCallback OnBlur { get; set; }
    [Parameter] public EventCallback OnFocus { get; set; }
    [Parameter] public string? Class { get; set; }
    [Parameter(CaptureUnmatchedValues = true)]
    public Dictionary<string, object>? AdditionalAttributes { get; set; }

    private string InputId { get; set; } = $"mx-input-{Guid.NewGuid():N[..8]}";
    private bool _isFocused;

    private string CurrentValueAsString => Value?.ToString() ?? "";

    private string WrapperClasses => $"mx-input-wrapper {Class}";

    private string ComputedClasses
    {
        get
        {
            var classes = new List<string> { "mx-input" };

            classes.Add(Size switch
            {
                MxInputSize.Small  => "px-2.5 py-1.5 text-xs",
                MxInputSize.Medium => "px-3 py-2 text-sm",
                MxInputSize.Large  => "px-4 py-2.5 text-base",
                _ => ""
            });

            if (HasError)
                classes.Add("border-danger-500 focus:ring-danger-500 focus:border-danger-500");

            if (PrefixContent != null)
                classes.Add("pl-10");

            if (SuffixContent != null || HasError)
                classes.Add("pr-10");

            return string.Join(" ", classes);
        }
    }

    private async Task HandleInput(ChangeEventArgs e)
    {
        if (ValueChanged.HasDelegate)
        {
            var value = (TValue)Convert.ChangeType(e.Value?.ToString() ?? "", typeof(TValue));
            await ValueChanged.InvokeAsync(value);
        }
    }

    private async Task HandleBlur()
    {
        _isFocused = false;
        if (OnBlur.HasDelegate) await OnBlur.InvokeAsync();
    }

    private async Task HandleFocus()
    {
        _isFocused = true;
        if (OnFocus.HasDelegate) await OnFocus.InvokeAsync();
    }
}

public enum MxInputSize { Small, Medium, Large }
